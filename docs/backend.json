
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "A fashion item in the Viloryi catalog.",
      "properties": {
        "id": { "type": "string", "description": "Unique product identifier." },
        "name": { "type": "string", "description": "Display name of the product." },
        "price": { "type": "number", "description": "Price in local currency (INR)." },
        "category": { 
          "type": "string",
          "description": "The ID of the category this product belongs to." 
        },
        "images": { 
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "Array of image URLs."
        },
        "description": { "type": "string", "description": "Marketing description." },
        "materials": { "type": "string", "description": "Fabric composition." },
        "details": { "type": "string", "description": "Styling details." },
        "sizes": { 
          "type": "array",
          "items": { "type": "string", "enum": ["XS", "S", "M", "L", "XL"] },
          "description": "Available sizes."
        },
        "stock": { "type": "number", "description": "Inventory count." },
        "createdAt": { "type": "string", "format": "date-time" },
        "isFeatured": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "category", "images", "description"]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Public product catalog."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Private user profiles."
        }
      }
    ]
  }
}
