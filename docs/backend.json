{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "A fashion item in the Viloryi catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "categoryId": { 
          "type": "string",
          "description": "The ID of the category this product belongs to." 
        },
        "fabric": { "type": "string" },
        "fit": { "type": "string" },
        "isFeatured": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "imageUrl", "categoryId"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "description": "A classification for products (e.g., Kurti Sets).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Public product catalog."
        }
      },
      {
        "path": "/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": { "$ref": "#/backend/entities/Category" },
          "description": "Product categories."
        }
      }
    ]
  }
}