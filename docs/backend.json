
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "A fashion item in the Viloryi catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { 
          "type": "string",
          "description": "The ID of the category this product belongs to (e.g., 'kurti')." 
        },
        "images": { 
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "Array of image URLs for the product."
        },
        "description": { "type": "string" },
        "materials": { "type": "string" },
        "details": { "type": "string" },
        "sizes": { 
          "type": "array",
          "items": { "type": "string", "enum": ["XS", "S", "M", "L", "XL"] } 
        },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isFeatured": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "category", "images", "description"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "description": "A classification for products (e.g., Kurti Sets).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Public product catalog."
        }
      },
      {
        "path": "/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": { "$ref": "#/backend/entities/Category" },
          "description": "Product categories."
        }
      }
    ]
  }
}
